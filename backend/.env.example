# Copie para .env e ajuste. Variáveis usam prefixo FADA_.
# Em dev nada é obrigatório — os padrões (SQLite, CORS aberto) já funcionam.
FADA_ENVIRONMENT=development

# Banco: padrão é SQLite (data/fada.db). Descomente para Postgres em produção:
# FADA_DATABASE_URL=postgresql+psycopg://fada:fada@localhost:5432/fada

# CORS — origens permitidas (CSV). "*" libera todas (dev). Em produção, restrinja:
# FADA_CORS_ORIGINS=https://app.suaempresa.com
FADA_CORS_ORIGINS=*

# Decision Engine (LLM) — opcional; o LLM só explica, nunca gera número (ADR-0002/0029).
# Sem nada configurado, a explicação é determinística (offline) e tudo funciona.
#
# Opção GRATUITA (recomendada): endpoint OpenAI-compatible com free tier (ex.: Groq —
# crie a chave grátis em console.groq.com). Basta a chave:
# FADA_FREE_LLM_API_KEY=
# FADA_FREE_LLM_BASE_URL=https://api.groq.com/openai/v1
# FADA_FREE_LLM_MODEL=llama-3.3-70b-versatile
#
# Opção paga (Anthropic):
FADA_ANTHROPIC_API_KEY=
FADA_LLM_ORCHESTRATOR_MODEL=claude-opus-4-8
FADA_LLM_CHEAP_MODEL=claude-haiku-4-5-20251001
# FADA_LLM_TIMEOUT_SECONDS=12
